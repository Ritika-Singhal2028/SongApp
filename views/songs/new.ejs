<%- include('../partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="text-center mb-4">Add New Song</h2>
        <form action="/songs" method="POST" class="needs-validation shadow p-4 rounded bg-white" novalidate>
            <div class="mb-3">
                <label class="form-label" for="songName">Song Name</label>
                <input class="form-control" type="text" id="songName" name="songName" required>
                <div class="invalid-feedback">Please provide a song name.</div>
            </div>
            <div class="mb-3">
                <label class="form-label" for="singer">Singer</label>
                <input class="form-control" type="text" id="singer" name="singer" required>
                <div class="invalid-feedback">Please provide the singer's name.</div>
            </div>
            <div class="mb-3">
                <label class="form-label" for="duration">Duration (e.g., 3:45)</label>
                <input class="form-control" type="text" id="duration" name="duration" required>
                <div class="invalid-feedback">Please provide the duration.</div>
            </div>
            <div class="d-grid">
                <button class="btn btn-success" type="submit">Add Song</button>
            </div>
        </form>
        <div class="mt-3 text-center">
            <a href="/songs" class="text-decoration-none">Back to All Songs</a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
