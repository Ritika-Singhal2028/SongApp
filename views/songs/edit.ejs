<%- include('../partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="text-center mb-4">Edit Song</h2>
        <form action="/songs/<%= song._id %>?_method=PUT" method="POST" class="needs-validation shadow p-4 rounded bg-white" novalidate>
            <div class="mb-3">
                <label class="form-label" for="songName">Song Name</label>
                <input class="form-control" type="text" id="songName" name="songName" value="<%= song.songName %>" required>
                <div class="invalid-feedback">Please provide a song name.</div>
                <small class="text-muted">Only the song name can be modified.</small>
            </div>
            <div class="mb-3">
                <label class="form-label" for="singer">Singer</label>
                <input class="form-control" type="text" id="singer" value="<%= song.singer %>" disabled>
            </div>
            <div class="mb-3">
                <label class="form-label" for="duration">Duration</label>
                <input class="form-control" type="text" id="duration" value="<%= song.duration %>" disabled>
            </div>
            <div class="d-grid">
                <button class="btn btn-primary" type="submit">Update Song</button>
            </div>
        </form>
        <div class="mt-3 text-center">
            <a href="/songs/<%= song._id %>" class="text-decoration-none">Back to Song</a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
